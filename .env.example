# Full PostgreSQL connection string (Supabase pooler example)
# DATABASE_DSN=postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
DATABASE_DSN=

# JWT signing secret — use a long random string
JWT_SECRET=change-me-to-a-long-random-string

# Single allowed user
ADMIN_EMAIL=john@veilstream.com
ADMIN_PASSWORD=change-me

# Frontend (web): API base URL and app version (for APK download link), baked in at build time
# VITE_API_URL=http://localhost:3000
# APP_VERSION=1.0.0

