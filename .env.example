# Full PostgreSQL connection string (e.g. Supabase). When set, the backend uses this and ignores
# DATABASE_HOST / POSTGRES_* for the URL. Leave empty to use the bundled docker-compose Postgres.
# DATABASE_DSN=postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
DATABASE_DSN=

# Used only when DATABASE_DSN is empty (default compose database)
# POSTGRES_USER=tasktracker
# POSTGRES_PASSWORD=tasktracker
# POSTGRES_DB=tasktracker
# DATABASE_HOST=postgres

# JWT signing secret — use a long random string
JWT_SECRET=change-me-to-a-long-random-string

# Single allowed user
ADMIN_EMAIL=john@veilstream.com
ADMIN_PASSWORD=change-me

# Frontend (web): API base URL and app version (for APK download link), baked in at build time
# VITE_API_URL=http://localhost:3000
# APP_VERSION=1.0.0

